{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "hrsu-indore",
  "compatibility_date": "2026-05-16",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "."
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "d1_databases": [
    { "binding": "DB", "database_name": "hrsu-store", "database_id": "PASTE-UUID-HERE" }
  ]
}
